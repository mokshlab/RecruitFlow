# RecruitFlow — MERN Stack Project
# All environment variable files are local-only. Never push them.
# Set env vars in your host's dashboard: Render (backend) and Vercel (frontend).

# ============================================================================
# ENVIRONMENT VARIABLES (all ignored — set on hosts, kept local only)
# ============================================================================
.env
.env.*
**/.env
**/.env.*

# ============================================================================
# DEPENDENCIES
# ============================================================================
node_modules/
# Note: package-lock.json is tracked for consistent dependencies across environments

# ============================================================================
# LOGS & RUNTIME DATA
# ============================================================================
logs/
*.log
npm-debug.log*

# ============================================================================
# BUILD OUTPUTS
# ============================================================================
# React build (Vercel generates during deployment)
/frontend/build/
/frontend/dist/
/backend/dist/

# ============================================================================
# TESTING & COVERAGE
# ============================================================================
coverage/
test-security.js

# ============================================================================
# USER UPLOADS
# ============================================================================
uploads/

# ============================================================================
# TEMPORARY FILES
# ============================================================================
*.tmp
*.swp
*.bak
*~
.cache/

# ============================================================================
# IDE SETTINGS
# ============================================================================
.vscode/
.idea/
*.sublime-workspace

# ============================================================================
# OPERATING SYSTEM
# ============================================================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================================================
# DEPLOYMENT
# ============================================================================
.vercel

# ============================================================================